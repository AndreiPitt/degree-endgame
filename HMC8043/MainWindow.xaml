<Window x:Class="HMC8043.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="HMC8043 Control" Height="270" Width="480">
    <StackPanel>
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Device ID" Margin="40 5" />
                <TextBox x:Name="TxtDeviceId" Margin="5 2" />
                <Button x:Name="BtnConnect" Click="BtnConnect_Click" Padding="5" Margin="10" Content="Connect"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="20">
                <TextBlock Text="Status" Margin="5" />
                <TextBlock x:Name="TxtStatus" Margin="5 2" Text="Deconectat" Foreground="Red" TextWrapping="Wrap"/>
            </StackPanel>
        </Grid>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <RadioButton x:Name="RbCh1" GroupName="Channels" IsChecked="True" Margin="10" Content="Channel 1" />
                <RadioButton x:Name="RbCh2" GroupName="Channels" Margin="10" Content="Channel 2"/>
                <RadioButton x:Name="RbCh3" GroupName="Channels" Margin="10" Content="Channel 3"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="0 5" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal">
                    <TextBox x:Name="TxtVoltage" Margin="5 2" Padding="80 0" />
                    <TextBlock Margin="5 2" Text="[V]"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBox x:Name="TxtCurrent" Margin="5 2" Padding="80 0" />
                    <TextBlock Margin="5 2" Text="[A]"/>
                </StackPanel>
                <Button x:Name="BtnApply" Click="BtnApply_Click" Padding="5" Margin="30 5 90 0" Content="Aplică Setările" />
            </StackPanel>

            <StackPanel Grid.Column="2">
                <TextBlock Margin="10 20 10 0" Text="Output"/>
                <Button x:Name="BtnOutput" Click="BtnOutput_Click" Padding="15" Margin="5" Background="LightGray"/>
            </StackPanel>
        </Grid>
    </StackPanel>
</Window>